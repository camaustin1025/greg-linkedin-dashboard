  const maxLift = Math.max(...computed.map(c => c.lift));

  document.getElementById('multGrid').innerHTML = `
    <div class="ranked-list">
      ${computed.map((c, i) => {
        const barPct = maxLift > 0 ? Math.round((c.lift / maxLift) * 100) : 0;
        const calloutHtml = c.callout ? `<div class="takeaway" style="margin:0 0 0 52px">${c.callout}</div>` : '';
        return `
          <div class="ranked-card">
            <div class="ranked-num">${c.emoji}</div>
            <div class="ranked-body">
              <div class="ranked-label">${c.element}</div>
              <div class="ranked-bar-track"><div class="ranked-bar-fill" style="width:${barPct}%"></div></div>
            </div>
            <div class="ranked-lift">${c.liftText}</div>
          </div>
          ${calloutHtml}
        `;
      }).join('')}
    </div>
  `;
}

// Horizontal bar chart
function renderHBar(containerId, data, colorIdx) {
  const maxVal = Math.max(...data.map(d => d.value));
  document.getElementById(containerId).innerHTML = data.map((d, i) => {
    const pct = maxVal > 0 ? (d.value / maxVal) * 100 : 0;
    const color = OG_CHART[colorIdx !== undefined ? colorIdx : i % OG_CHART.length];
    return `
      <div class="hbar-row">
        <div class="hbar-label">${d.label}</div>
        <div class="hbar-track">
          <div class="hbar-fill" style="width:${pct}%;background:${color}">${d.value}</div>
        </div>
        <div class="hbar-meta">n=${d.count}</div>
      </div>
    `;
  }).join('');
}

function renderCharts() {
  const fmtGroups = groupBy(DATA, 't');
  renderHBar('chartFormat', Object.entries(fmtGroups).map(([k,v]) => ({
    label: k, value: median(v.map(d=>d.e)), count: v.length
  })).sort((a,b) => b.value - a.value), 1);

  const opLabels = { narrative:'Narrative hook', announcement:'Announcement', emotion:'Emotion lead', question:'Question', other:'Other', link_only:'Link only' };
  const opGroups = groupBy(DATA, 'op');
  renderHBar('chartOpener', Object.entries(opGroups).map(([k,v]) => ({
    label: opLabels[k]||k, value: median(v.map(d=>d.e)), count: v.length
  })).sort((a,b) => b.value - a.value), 0);

  const arLabels = { customer_win:'Customer Win', culture:'Culture/Team', hiring:'Hiring', industry_pov:'Industry POV', event:'Event', other:'Other' };
  const arGroups = groupBy(DATA, 'ar');
  renderHBar('chartArchetype', Object.entries(arGroups).map(([k,v]) => ({
    label: arLabels[k]||k, value: median(v.map(d=>d.e)), count: v.length
  })).sort((a,b) => b.value - a.value), 3);

  const clLabels = { question:'Question', gratitude:'Gratitude', cta:'Call to Action', statement:'Statement', hashtag:'Hashtag', link:'Bare Link' };
  const clGroups = groupBy(DATA, 'cl');
  renderHBar('chartCloser', Object.entries(clGroups).map(([k,v]) => ({
    label: clLabels[k]||k, value: median(v.map(d=>d.e)), count: v.length
  })).sort((a,b) => b.value - a.value), 2);

  const lbLabels = { short:'1-25 words', medium:'26-60 words', long:'61-100 words', extended:'100+ words' };
  const lbOrder = ['extended','long','medium','short'];
  const lbGroups = groupBy(DATA, 'lb');
  renderHBar('chartLength', lbOrder.filter(k => lbGroups[k]).map(k => ({
    label: lbLabels[k], value: median(lbGroups[k].map(d=>d.e)), count: lbGroups[k].length
  })), 8);

  const yrGroups = groupBy(DATA.filter(d=>d.y), 'y');
  renderHBar('chartYear', Object.entries(yrGroups).sort((a,b) => b[0]-a[0]).map(([k,v]) => ({
    label: k, value: median(v.map(d=>d.e)), count: v.length
  })), 1);
}

// Dot strip
function renderDotStrip() {
  const sorted = [...DATA].sort((a,b) => b.e - a.e);
  const maxE = sorted[0].e;
  const q1 = sorted[Math.floor(sorted.length * 0.25)].e;
  const q3 = sorted[Math.floor(sorted.length * 0.75)].e;
  const tooltip = document.getElementById('tooltip');
  const container = document.getElementById('dotStrip');

  container.innerHTML = sorted.map((d,i) => {
    const h = Math.max(3, (d.e / maxE) * 100);
    const cls = d.e >= q1 ? 'top' : d.e >= q3 ? 'mid' : 'low';
    return `<div class="dot-strip-bar ${cls}" style="height:${h}%" data-idx="${i}"></div>`;
  }).join('');

  container.addEventListener('mousemove', (ev) => {
    const bar = ev.target.closest('.dot-strip-bar');
    if (!bar) { tooltip.style.display = 'none'; return; }
    const d = sorted[parseInt(bar.dataset.idx)];
    tooltip.innerHTML = `
      <div class="tt-eng">${d.e} engagement</div>
      <div class="tt-meta">${d.l} likes &middot; ${d.cm} comments &middot; ${d.r} reposts &middot; ${d.w} words &middot; ${d.t}</div>
      <div class="tt-content">"${d.c}..."</div>
    `;
    tooltip.style.display = 'block';
    const rect = bar.getBoundingClientRect();
    tooltip.style.left = Math.min(rect.left, window.innerWidth - 360) + 'px';
    tooltip.style.top = (rect.top - tooltip.offsetHeight - 8) + 'px';
  });
  container.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
}

// Post feed with filters
let currentFilter = 'all';
function renderPostFeed() {
  const archetypes = ['all', 'customer_win', 'culture', 'hiring', 'industry_pov', 'event', 'other'];
  const archetypeLabels = { all:'All', customer_win:'Customer Win', culture:'Culture', hiring:'Hiring', industry_pov:'Industry POV', event:'Event', other:'Other' };
  const archetypeColors = {
    customer_win:['var(--green-dim)','var(--og-green)'],
    culture:['var(--blue-dim)','var(--blue)'],
    hiring:['var(--yellow-dim)','var(--yellow)'],
    industry_pov:['var(--purple-dim)','var(--purple)'],
    event:['rgba(0,250,255,0.1)','#0080B0'],
    other:['var(--surface)','var(--text-muted)']
  };

  document.getElementById('filterBar').innerHTML = archetypes.map(a => `
    <button class="filter-pill ${currentFilter === a ? 'active' : ''}" data-filter="${a}">${archetypeLabels[a]}</button>
  `).join('');

  document.getElementById('filterBar').addEventListener('click', (ev) => {
    const btn = ev.target.closest('.filter-pill');
    if (!btn) return;
    currentFilter = btn.dataset.filter;
    renderPostFeed();
  });

  let filtered = currentFilter === 'all' ? DATA : DATA.filter(d => d.ar === currentFilter);
  const sorted = [...filtered].sort((a,b) => b.e - a.e).slice(0, 20);

  document.getElementById('postFeed').innerHTML = sorted.map((d, i) => {
    const [bgCol, txtCol] = archetypeColors[d.ar] || archetypeColors.other;
    const tags = [];
    if (d.fp) tags.push(['1P', 'var(--green-dim)', 'var(--og-green)']);
    if (d.br) tags.push(['Brand', 'rgba(0,250,255,0.1)', '#0080B0']);
    if (d.dt) tags.push(['Data', 'var(--purple-dim)', 'var(--purple)']);
    const rank = i + 1;
    const inner = `
        <div class="post-rank">#${rank}</div>
        <div class="post-content">${d.c}</div>
        <div class="post-tags">
          <span class="post-tag" style="background:${bgCol};color:${txtCol}">${archetypeLabels[d.ar] || d.ar}</span>
          ${tags.map(([lbl,bg,fg]) => `<span class="post-tag" style="background:${bg};color:${fg}">${lbl}</span>`).join('')}
        </div>`;
    return d.url
      ? `<a href="${d.url}" target="_blank" rel="noopener" class="post-row post-link">${inner}</a>`
      : `<div class="post-row">${inner}</div>`;
  }).join('');
}

renderStats();
renderMultipliers();
renderCharts();
renderDotStrip();
renderPostFeed();
</script>
