// OG chart palette (solid colors, no gradients per brand spec)
const OG_CHART = ['#00FF85','#009A50','#00FAFF','#0080B0','#004F8C','#EAFF00','#FF8C00','#D46AFF','#7821F5'];

function median(arr) {
  if (!arr.length) return 0;
  const s = [...arr].sort((a,b) => a-b);
  const mid = Math.floor(s.length/2);
  return s.length % 2 ? s[mid] : (s[mid-1] + s[mid]) / 2;
}

function groupBy(arr, key) {
  const groups = {};
  arr.forEach(item => {
    const k = typeof key === 'function' ? key(item) : item[key];
    if (!groups[k]) groups[k] = [];
    groups[k].push(item);
  });
  return groups;
}

// Stats row
function renderStats() {
  const engagements = DATA.map(d => d.e);
  const totalEng = engagements.reduce((a,b) => a+b, 0);
  const med = median(engagements);
  const topQ = DATA.filter(d => d.e >= 53).length;
  document.getElementById('statsRow').innerHTML = [
    { label: 'Total Posts', value: DATA.length, sub: 'Greg originals only' },
    { label: 'Total Engagement', value: totalEng.toLocaleString(), sub: 'likes + comments + reposts' },
    { label: 'Median Engagement', value: med, sub: 'per post' },
    { label: 'Top Quartile', value: topQ, sub: 'posts with 53+ engagement' },
  ].map((s,i) => `
    <div class="stat-card animate-in" style="animation-delay:${0.04 + i*0.05}s">
      <div class="stat-label">${s.label}</div>
      <div class="stat-value">${s.value}</div>
      <div class="stat-sub">${s.sub}</div>
    </div>
  `).join('');
}

